# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# local dev / e2e artifacts
/frontend/test-results/
/frontend/playwright-report/
/frontend/devserver.*.log
/backend/backend-dev.*.log
